<Window x:Class="MemoryWatchDogApp.ObjectDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:MemoryWatchDogApp.Converters"
        Title="Object Details" Height="600" Width="1000"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Object list -->
        <DockPanel Grid.Column="0">
            <TextBlock DockPanel.Dock="Top" x:Name="TypeNameHeader" FontWeight="Bold" FontSize="14"
                 Margin="0,0,0,2" TextWrapping="Wrap"/>
            <TextBlock DockPanel.Dock="Top" x:Name="ObjectCountText" Foreground="Gray" Margin="0,0,0,4"/>
            <CheckBox DockPanel.Dock="Top" x:Name="FilterReferencedCheckBox" Content="Only with references"
                Margin="0,0,0,8" Checked="FilterReferencedCheckBox_Changed" Unchecked="FilterReferencedCheckBox_Changed"/>
            <ListBox x:Name="ObjectListBox" SelectionChanged="ObjectListBox_SelectionChanged"
               HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding ObjectInfo.TypeName}" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding ReferenceCountText}" Foreground="#E65100" FontSize="11" Margin="8,0,0,0"/>
                                <!--<TextBlock Grid.Column="2" Text="{Binding AddressText}" FontFamily="Consolas" FontSize="12" Margin="8,0,0,0"/>-->
                                <TextBlock Grid.Column="3" Text="{Binding SizeText}" Foreground="Gray" FontSize="11" Margin="8,0,0,0"/>
                            </Grid>
                            <TextBlock Text="{Binding DisplayValueText}" Foreground="#1565C0" FontSize="11"
                         TextTrimming="CharacterEllipsis" Margin="0,2,0,0"
                         Visibility="{Binding DisplayValueText, Converter={StaticResource StringToVisibilityConverter}}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center"
                  VerticalAlignment="Stretch" Background="LightGray" Margin="3,0"/>

        <!-- Right: Dependency & Retention graphs -->
        <TabControl Grid.Column="2" Margin="5,0,0,0">
            <TabItem Header="Dependency Graph">
                <Grid>
                    <TextBlock x:Name="NoSelectionText"
                         Text="Select an object from the list to view its dependencies."
                         Foreground="Gray" FontStyle="Italic" VerticalAlignment="Top" Margin="5"/>
                    <ScrollViewer x:Name="GraphScrollViewer" Visibility="Collapsed"
                            VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <Canvas x:Name="GraphCanvas"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            <TabItem Header="Retention Graph">
                <Grid>
                    <TextBlock x:Name="RetentionNoSelectionText"
                         Text="Select an object from the list to view the retention graph."
                         Foreground="Gray" FontStyle="Italic" VerticalAlignment="Top" Margin="5"/>
                    <TreeView x:Name="RetentionTreeView" Visibility="Collapsed"
                        VirtualizingStackPanel.IsVirtualizing="True"
                        VirtualizingStackPanel.VirtualizationMode="Recycling"
                        BorderThickness="0">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="11"
                                         TextWrapping="NoWrap"/>
                                    <TextBlock Text="{Binding DetailText}" Foreground="Gray" FontSize="10"
                                         Margin="8,1,0,0" FontFamily="Consolas"/>
                                    <TextBlock Text="{Binding ReferenceCountText}" Foreground="#E65100" FontSize="10"
                                         Margin="8,1,0,0"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
