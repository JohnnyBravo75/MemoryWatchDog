<UserControl x:Class="MemoryWatchDogApp.MemoryGraphControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="150">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" Background="White">
            <Canvas x:Name="GraphCanvas" ClipToBounds="True" SizeChanged="GraphCanvas_SizeChanged"/>
        </Border>
        <ItemsControl Grid.Column="1" x:Name="LegendList" Margin="8,0,0,0" VerticalAlignment="Top">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Rectangle Width="14" Height="3" Fill="{Binding ColorBrush}" Margin="0,0,5,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Label}" FontSize="11" FontFamily="Consolas"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
