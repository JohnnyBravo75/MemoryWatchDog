<Window x:Class="MemoryWatchDogApp.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MemoryWatchDogApp"
        mc:Ignorable="d"
        Title=".NET MemoryWatchDog" Height="850" Width="1100" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Process Selection -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.RowDefinitions>
                <RowDefinition  Height="Auto" />
                <RowDefinition  Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="ProcessHeader" Grid.Column="0" FontWeight="Bold" FontSize="14"
                       Text="Process" VerticalAlignment="Center" Margin="0,0,0,3"/>
            <Button x:Name="SelectProcessButton" Grid.Row="1" Grid.Column="0" Content="Attach to Process"
                    Width="120" Click="SelectProcessButton_Click"
                    ToolTip="Open dialog to select a process"/>
            <TextBlock x:Name="SelectedProcessText" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center"
                       Margin="10,0,0,0" FontSize="14" Foreground="Blue"
                       Text="No process selected"/>
        </Grid>

        <!-- Live Profiling Panel -->
        <Border Grid.Row="1" x:Name="ProfilingPanel" Visibility="Visible"
                BorderBrush="#336699" BorderThickness="1" CornerRadius="3"
                Background="#F0F4FA" Margin="0,0,0,8" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,5">
                    <TextBlock Text="Live Memory Profiling" FontWeight="Bold" FontSize="14"
                               VerticalAlignment="Center" DockPanel.Dock="Left"/>
                    <TextBlock x:Name="ProfilingStatusText" VerticalAlignment="Center"
                               Margin="15,0,0,0" Foreground="DarkBlue" DockPanel.Dock="Left"
                               FontFamily="Consolas" FontSize="12"/>
                    <Button x:Name="StopProfilingButton" Content="Stop Profiling" Width="110"
                            DockPanel.Dock="Right" HorizontalAlignment="Right"
                            Click="StopProfilingButton_Click" IsEnabled="False"
                            ToolTip="Stop live memory profiling and detach from the process"/>
                    <Button x:Name="StartProfilingButton" Content="Start Profiling" Width="110"
                            Margin="5,0,0,0" DockPanel.Dock="Right" HorizontalAlignment="Right" Click="StartProfilingButton_Click" IsEnabled="False"
                            ToolTip="Start continuous memory profiling of the selected process"/>
                </DockPanel>
                <local:MemoryGraphControl Grid.Row="1" x:Name="MemoryGraph"/>
            </Grid>
        </Border>

        <!-- Stats Filter -->
        <Grid Grid.Row="2" Margin="0,10,0,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="CaptureHeader" Grid.Row="0" Grid.Column="0" FontWeight="Bold" FontSize="14"
           Text="Capture" VerticalAlignment="Center" Margin="0,0,0,3"/>
            <CheckBox x:Name="ExcludeSystemNamespacesCheckBox" Grid.Row="1" Grid.Column="0" Margin="0,0,10,0"
                      Content="Exclude System Namespaces" VerticalAlignment="Center"
                      IsChecked="True"
                      ToolTip="Exclude common system namespaces (System, Microsoft, Windows, etc.) from heap object results"/>
            <CheckBox x:Name="AggregateObjectsCheckBox" Grid.Row="1" Grid.Column="1" Margin="0,0,10,0"
                      Content="Aggregate Objects" VerticalAlignment="Center"
                      IsChecked="False"
                      ToolTip="Aggregate heap objects by type name (faster and uses less memory. For a detailed view, uncheck this option)"/>
            <Button x:Name="AttachButton" Grid.Row="1" Grid.Column="3" Content="Get Memory Snapshot" Width="150" 
                    Click="AttachButton_Click" IsEnabled="False"/>
            <Button x:Name="ForceGCButton" Grid.Row="1" Grid.Column="4" Content="Force GC" Width="80"
                    Margin="5,0,0,0" Click="ForceGCButton_Click" IsEnabled="False"
                    ToolTip="Force garbage collection on the attached process"/>

        </Grid>

        <!-- Capture Progress -->
        <StackPanel Grid.Row="3" x:Name="CaptureProgressPanel" Orientation="Horizontal" Margin="0,5,0,0" Visibility="Collapsed">
            <TextBlock x:Name="CaptureProgressText" VerticalAlignment="Center" Margin="0,0,10,0"
                       Text="Objects: 0 | Types: 0" Foreground="DarkBlue"/>
            <ProgressBar x:Name="CaptureProgressBar" Width="200" Height="16" IsIndeterminate="True"/>
            <Button x:Name="CancelButton" Grid.Column="4" Content="Cancel" Width="60" 
                Margin="5,0,0,0" Click="CancelButton_Click" IsEnabled="False"
                ToolTip="Cancel the running capture"/>
        </StackPanel>

        <!-- Stats Header -->
        <Grid Grid.Row="4" Margin="0,10,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatsHeader" Grid.Column="0" FontWeight="Bold" FontSize="14"
                       Text="Memory Statistics" VerticalAlignment="Center"/>

            <TextBlock x:Name="StatusText" Grid.Column="3" VerticalAlignment="Center"
                       Foreground="Gray"/>
        </Grid>

        <!-- Memory Stats Display -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Snapshots List -->
            <DockPanel Grid.Column="0" Margin="0,0,5,0">
                <TextBlock DockPanel.Dock="Top" Text="Snapshots" FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                <Button x:Name="RemoveSnapshotButton" DockPanel.Dock="Bottom" Content="Remove Selected" Margin="0,4,0,0"
                        Click="RemoveSnapshotButton_Click" IsEnabled="False"
                        ToolTip="Remove the selected snapshot from the list"/>
                <ListBox x:Name="SnapshotsListBox" SelectionChanged="SnapshotsListBox_SelectionChanged"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2">
                                <TextBlock Text="{Binding DisplayDate}" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="{Binding DisplayProcess}" FontSize="11" Foreground="Gray"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <TabControl Grid.Column="1">
            <TabItem Header="Overview">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock x:Name="OverviewText" TextWrapping="Wrap"
                                   FontFamily="Consolas" FontSize="13"
                                   Text="Select a process and click 'Get Memory Stats' to view statistics."/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Heap Objects">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Filter Type Name:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="ObjectsFilterTextBox" Grid.Column="1"
                                 TextChanged="ObjectsFilterTextBox_TextChanged"
                                 ToolTip="Type to filter heap objects by type name"/>
                    </Grid>
                    <DataGrid x:Name="ObjectsGrid" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserSortColumns="True" HorizontalGridLinesBrush="LightGray" VerticalGridLinesBrush="LightGray"
                              MouseDoubleClick="ObjectsGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Type Name" Binding="{Binding TypeName}" Width="*"/>
                            <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="80"
                                                SortDirection="Descending">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Total Size (bytes)" Binding="{Binding Size}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Element Type" Binding="{Binding ElementType}" Width="120"/>
                            <DataGridTextColumn Header="Assembly" Binding="{Binding AssemblyName}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="Threads">
                <DataGrid x:Name="ThreadsGrid" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserSortColumns="True" HorizontalGridLinesBrush="LightGray" VerticalGridLinesBrush="LightGray"
                          >
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="120"/>
                        <DataGridTextColumn Header="Managed Thread ID" Binding="{Binding ManagedThreadId}" Width="140"/>
                        <DataGridTextColumn Header="OS Thread ID" Binding="{Binding OSThreadId}" Width="120"/>
                        <!--<DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="180"/>-->
                        <DataGridTextColumn Header="CurrentException" Binding="{Binding CurrentExceptionType}" Width="180"/>
                        <DataGridTextColumn Header="StackFrames" Binding="{Binding StackFramesAll}" Width="180"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem x:Name="PotentialLeaksTab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Potential Leaks" Foreground="Red" FontWeight="Bold"/>
                        <TextBlock x:Name="PotentialLeaksCountText" Foreground="Red" FontWeight="Bold" Margin="4,0,0,0"/>
                    </StackPanel>
                </TabItem.Header>
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="5"
                               Text="Objects that have been disposed but are still retained in memory. These are potential memory leaks."
                               Foreground="Gray" FontStyle="Italic" TextWrapping="Wrap"/>
                    <DataGrid x:Name="PotentialLeaksGrid" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserSortColumns="True"
                              HorizontalGridLinesBrush="LightGray" VerticalGridLinesBrush="LightGray"
                              MouseDoubleClick="PotentialLeaksGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Type Name" Binding="{Binding TypeName}" Width="*"/>
                            <DataGridTextColumn Header="Size (bytes)" Binding="{Binding Size}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Display Value" Binding="{Binding DisplayValue}" Width="200"/>
                            <DataGridTextColumn Header="References" Binding="{Binding ReferenceCount}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Element Type" Binding="{Binding ElementType}" Width="120"/>
                            <DataGridTextColumn Header="Assembly" Binding="{Binding AssemblyName}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>
        </Grid>

        <!-- Status bar -->
        <Grid Grid.Row="6">
            <StackPanel Orientation="Horizontal">
                <!--<Button x:Name="ExportTxtButton" Grid.Column="1" Content="Export TXT" Width="90"
                 Margin="0,0,5,0" Click="ExportTxtButton_Click" IsEnabled="False"
                 ToolTip="Export the current memory snapshot to a text file"/>-->
                <Button x:Name="ExportJsonButton" Grid.Column="2" Content="Export to file" Width="90"
                 Margin="0,0,10,0" Click="ExportJsonButton_Click" IsEnabled="False"
                 ToolTip="Export the current memory snapshot to a JSON file"/>
                <Button x:Name="ImportJsonButton" Content="Import from file" Width="90"
                 Margin="0,0,5,0" Click="ImportJsonButton_Click"
                 ToolTip="Load a memory snapshot from a JSON file"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
