<Window x:Class="MemoryWatchDogApp.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MemoryWatchDogApp"
        mc:Ignorable="d"
        Title=".NET MemoryWatchDog" Height="700" Width="1000" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="ProcessHeader" Grid.Column="0" FontWeight="Bold" FontSize="14"
            Text="Processes" VerticalAlignment="Center"/>

        <!-- Process Search & Refresh -->
        <Grid Grid.Row="1" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Filter:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="FilterTextBox" Grid.Column="1" Margin="0,0,5,0"
                     TextChanged="FilterTextBox_TextChanged"
                     ToolTip="Type to filter processes by name or PID"/>
            <CheckBox x:Name="DotNetOnlyCheckBox" Grid.Column="2" Content=".NET only"
                      VerticalAlignment="Center" Margin="0,0,10,0"
                      Checked="DotNetOnlyCheckBox_Changed" Unchecked="DotNetOnlyCheckBox_Changed"
                      ToolTip="Show only .NET processes (detects CLR version for each process)"/>
            <Button x:Name="RefreshButton" Grid.Column="3" Content="Refresh" Width="80"
                    Margin="0,0,5,0" Click="RefreshButton_Click"/>

        </Grid>

        <!-- Process List -->
        <DataGrid x:Name="ProcessGrid" Grid.Row="2" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single" HorizontalGridLinesBrush="LightGray" VerticalGridLinesBrush="LightGray"
                  SelectionChanged="ProcessGrid_SelectionChanged"
                  CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="PID" Binding="{Binding Id}" Width="70"/>
                <DataGridTextColumn Header="Process Name" Binding="{Binding ProcessName}" Width="200"/>
                <DataGridTextColumn Header="Memory (MB)" Binding="{Binding MemoryMB}" Width="100"/>
                <DataGridTextColumn Header=".NET Version" Binding="{Binding NETVersion}" Width="100"/>
                <DataGridTextColumn Header="Window Title" Binding="{Binding MainWindowTitle}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Stats Filter -->
        <Grid Grid.Row="3" Margin="0,10,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="ExcludeSystemNamespacesCheckBox" Grid.Column="0" Margin="0,0,10,0"
                      Content="Exclude System Namespaces" VerticalAlignment="Center"
                      IsChecked="True"
                      ToolTip="Exclude common system namespaces (System, Microsoft, Windows, etc.) from heap object results"/>
            <CheckBox x:Name="AggregateObjectsCheckBox" Grid.Column="1" Margin="0,0,10,0"
                      Content="Aggregate Objects" VerticalAlignment="Center"
                      IsChecked="True"
                      ToolTip="Aggregate heap objects by type name (faster and uses less memory. For a detailed view, uncheck this option)"/>
            <Button x:Name="AttachButton" Grid.Column="3" Content="Get Memory Snapshot" Width="150" 
                    Click="AttachButton_Click" IsEnabled="False"/>
        </Grid>

        <!-- Stats Header -->
        <Grid Grid.Row="4" Margin="0,10,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatsHeader" Grid.Column="0" FontWeight="Bold" FontSize="14"
                       Text="Memory Statistics" VerticalAlignment="Center"/>

            <TextBlock x:Name="StatusText" Grid.Column="3" VerticalAlignment="Center"
                       Foreground="Gray"/>
        </Grid>

        <!-- Memory Stats Display -->
        <TabControl Grid.Row="5">
            <TabItem Header="Overview">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock x:Name="OverviewText" TextWrapping="Wrap"
                                   FontFamily="Consolas" FontSize="13"
                                   Text="Select a process and click 'Get Memory Stats' to view statistics."/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Heap Objects">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Filter Type Name:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="ObjectsFilterTextBox" Grid.Column="1"
                                 TextChanged="ObjectsFilterTextBox_TextChanged"
                                 ToolTip="Type to filter heap objects by type name"/>
                    </Grid>
                    <DataGrid x:Name="ObjectsGrid" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserSortColumns="True" HorizontalGridLinesBrush="LightGray" VerticalGridLinesBrush="LightGray"
                              MouseDoubleClick="ObjectsGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Type Name" Binding="{Binding TypeName}" Width="*"/>
                            <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="80"
                                                SortDirection="Descending">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Total Size (bytes)" Binding="{Binding Size}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Element Type" Binding="{Binding ElementType}" Width="120"/>
                            <DataGridTextColumn Header="Assembly" Binding="{Binding AssemblyName}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="Threads">
                <DataGrid x:Name="ThreadsGrid" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserSortColumns="True" HorizontalGridLinesBrush="LightGray" VerticalGridLinesBrush="LightGray"
                          >
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Managed Thread ID" Binding="{Binding ManagedThreadId}" Width="140"/>
                        <DataGridTextColumn Header="OS Thread ID" Binding="{Binding OSThreadId}" Width="120"/>
                        <DataGridTextColumn Header="State" Binding="{Binding State}" Width="*"/>
                        <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="180"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <!-- Status bar -->
        <Grid Grid.Row="6">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="ExportTxtButton" Grid.Column="1" Content="Export TXT" Width="90"
                 Margin="0,0,5,0" Click="ExportTxtButton_Click" IsEnabled="False"
                 ToolTip="Export the current memory snapshot to a text file"/>
                <Button x:Name="ExportJsonButton" Grid.Column="2" Content="Export JSON" Width="90"
                 Margin="0,0,10,0" Click="ExportJsonButton_Click" IsEnabled="False"
                 ToolTip="Export the current memory snapshot to a JSON file"/>
                <Button x:Name="ImportJsonButton" Content="Import JSON" Width="90"
                 Margin="0,0,5,0" Click="ImportJsonButton_Click"
                 ToolTip="Load a memory snapshot from a JSON file"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
