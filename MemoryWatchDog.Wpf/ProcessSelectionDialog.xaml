<Window x:Class="MemoryWatchDogApp.ProcessSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Process" Height="500" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Process Search & Refresh -->
        <Grid Grid.Row="0" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Filter:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="FilterTextBox" Grid.Column="1" Margin="0,0,5,0"
                     TextChanged="FilterTextBox_TextChanged"
                     ToolTip="Type to filter processes by name or PID"/>
            <CheckBox x:Name="DotNetOnlyCheckBox" Grid.Column="2" Content=".NET only"
                      VerticalAlignment="Center" Margin="0,0,10,0"
                      Checked="DotNetOnlyCheckBox_Changed" Unchecked="DotNetOnlyCheckBox_Changed"
                      ToolTip="Show only .NET processes (detects CLR version for each process)"/>
            <Button x:Name="RefreshButton" Grid.Column="3" Content="Refresh" Width="80"
                    Margin="0,0,5,0" Click="RefreshButton_Click"/>
        </Grid>

        <!-- Process List -->
        <DataGrid x:Name="ProcessGrid" Grid.Row="1" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single" HorizontalGridLinesBrush="LightGray" VerticalGridLinesBrush="LightGray"
                  SelectionChanged="ProcessGrid_SelectionChanged"
                  MouseDoubleClick="ProcessGrid_MouseDoubleClick"
                  CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="PID" Binding="{Binding Id}" Width="70"/>
                <DataGridTextColumn Header="Process Name" Binding="{Binding ProcessName}" Width="200"/>
                <DataGridTextColumn Header="Memory (MB)" Binding="{Binding MemoryMB}" Width="100"/>
                <DataGridTextColumn Header=".NET Version" Binding="{Binding NETVersion}" Width="100"/>
                <DataGridTextColumn Header="Window Title" Binding="{Binding MainWindowTitle}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- OK / Cancel -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" Grid.Column="0" VerticalAlignment="Center" Foreground="Gray"/>
            <Button x:Name="OkButton" Grid.Column="2" Content="OK" Width="80" Margin="0,0,5,0"
                    Click="OkButton_Click" IsEnabled="False" IsDefault="True"/>
            <Button Grid.Column="3" Content="Cancel" Width="80"
                    Click="CancelButton_Click" IsCancel="True"/>
        </Grid>
    </Grid>
</Window>
